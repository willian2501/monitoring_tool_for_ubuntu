# Copy this file to .env and adjust the values for your host.

MONITORING_PORT=8080

# Host paths mounted read-only into the monitoring container.
HOST_CADDY_LOG_DIR=/var/log/caddy
HOST_CONTAINER_LOG_ROOT=/var/lib/docker/containers

# Path inside the container for config explorer.
# Because the host root is mounted at /host-root, a host path like /opt/my-stack
# becomes /host-root/opt/my-stack inside the container.
CONFIG_ROOT_PATH=/host-root

# Monitoring behavior.
DATA_RETENTION_DAYS=7
COLLECTION_INTERVAL_MS=180000
HOST_COLLECTION_INTERVAL_MS=30000

# Optional comma-separated values.
SELECTED_LOG_CONTAINERS=
SERVICE_PROBES=

# Optional reverse proxy values if you use the Caddy example.
MONITORING_DOMAIN=monitoring.example.com
CADDY_ACME_EMAIL=admin@example.com